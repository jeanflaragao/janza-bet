# Copie este arquivo para .env e preencha os valores antes de rodar o docker compose
# cp .env.example .env

# Usuário do MySQL — use "root" para que o Rails possa criar os bancos auxiliares
# (cache, queue, cable) automaticamente via db:prepare
MYSQLUSER=root

# Senha do root do MySQL (e do usuário da aplicação se MYSQLUSER != root)
MYSQLPASSWORD=troque_por_uma_senha_forte

# Nome do banco de dados principal da aplicação
DB_NAME=janza_bet_production

# Chave mestra do Rails — valor do arquivo config/master.key
# cat config/master.key
RAILS_MASTER_KEY=

# Porta onde a aplicação ficará disponível no host (padrão: 80)
APP_PORT=80
