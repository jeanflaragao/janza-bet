# Copy this file to .env and fill in the values before running docker compose
# cp .env.example .env

# ─── Database ─────────────────────────────────────────────────────────────────
# Use "root" so Rails can create auxiliary databases (cache, queue, cable)
# automatically via db:prepare.
MYSQLUSER=root
MYSQLPASSWORD=troque_por_uma_senha_forte
MYSQLHOST=127.0.0.1
MYSQLPORT=3307
DB_NAME=janza_bet_development

# ─── Rails ────────────────────────────────────────────────────────────────────
# Uncomment ONE of the two options below:

# Option 1 – master key (decrypts config/credentials.yml.enc)
#   cat config/master.key
# RAILS_MASTER_KEY=

# Option 2 – secret key base directly (simpler for local dev)
#   bundle exec rails secret
# SECRET_KEY_BASE=

# ─── Docker Compose ───────────────────────────────────────────────────────────
# Port where the app will be available on the host (default: 80)
APP_PORT=80
