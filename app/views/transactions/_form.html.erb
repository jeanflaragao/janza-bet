<%= form_with(model: transaction, id: "form_transaction") do |f| %>
<% if transaction.errors.any? %>
<div class="mb-4 p-3 bg-red-500/15 border border-red-500/30 rounded-md" role="alert">
    <p class="text-sm font-medium text-red-300 mb-1">Por favor corrija os erros abaixo:</p>
    <ul class="list-disc list-inside text-sm text-red-400 space-y-0.5">
        <% transaction.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
        <% end %>
    </ul>
</div>
<% end %>

<div class="flex flex-wrap gap-4 items-end">
    <div class="form-group">
        <%= f.label :date, "Data", class: "block text-sm font-medium text-slate-300 mb-1" %>
        <%= f.date_field :date, class: "bg-slate-900 border border-white/10 text-white w-full rounded-md p-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div class="form-group">
        <%= f.label :book_id, "Casa de aposta", class: "block text-sm font-medium text-slate-300 mb-1" %>
        <%= f.collection_select :book_id,
            current_user.books.where(inactive: false).order(:description),
            :id,
            :description,
            { prompt: "Selecione a casa" },
            { class: "bg-slate-900 border border-white/10 text-white rounded-md p-2 w-48 focus:ring-indigo-500 focus:border-indigo-500" } %>
    </div>

    <div class="form-group">
        <%= f.label :transaction_type, "Tipo", class: "block text-sm font-medium text-slate-300 mb-1" %>
        <%= f.select :transaction_type, [["Depósito", "deposit"], ["Saque", "withdraw"]],
            { prompt: "Selecione o tipo" },
            { class: "bg-slate-900 border border-white/10 text-white rounded-md p-2 w-48 focus:ring-indigo-500 focus:border-indigo-500" } %>
    </div>

    <div class="form-group">
        <%= f.label :amount, "Valor", class: "block text-sm font-medium text-slate-300 mb-1" %>
        <%= f.number_field :amount, placeholder: "0.00",
            class: "bg-slate-900 border border-white/10 text-white placeholder-slate-500 rounded-md p-2 w-40 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div class="form-group">
        <%= f.submit "Criar",
            class: "px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-lg transition-colors cursor-pointer" %>
    </div>
</div>
<% end %>
