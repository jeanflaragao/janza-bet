<%= form_with(model: transaction, id: "form_transaction") do |f| %>
<% if transaction.errors.any? %>
<div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-md" role="alert">
    <p class="text-sm font-medium text-red-700 mb-1">Por favor corrija os erros abaixo:</p>
    <ul class="list-disc list-inside text-sm text-red-600 space-y-0.5">
        <% transaction.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
        <% end %>
    </ul>
</div>
<% end %>

<div class="flex flex-wrap gap-4 items-end">
    <div class="form-group">
        <%= f.label :date, "Data", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :date, class: "w-full border border-gray-300 rounded-md p-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div class="form-group">
        <%= f.label :book_id, "Casa de aposta", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.collection_select :book_id,
            current_user.books.where(inactive: false).order(:description),
            :id,
            :description,
            { prompt: "Selecione a casa" },
            { class: "border border-gray-300 rounded-md p-2 w-48 focus:ring-blue-500 focus:border-blue-500" } %>
    </div>

    <div class="form-group">
        <%= f.label :transaction_type, "Tipo", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :transaction_type, [["Depósito", "deposit"], ["Saque", "withdraw"]],
            { prompt: "Selecione o tipo" },
            { class: "border border-gray-300 rounded-md p-2 w-48 focus:ring-blue-500 focus:border-blue-500" } %>
    </div>

    <div class="form-group">
        <%= f.label :amount, "Valor", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :amount, placeholder: "0.00",
            class: "border border-gray-300 rounded-md p-2 w-40 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div class="form-group">
        <%= f.submit "Criar",
            class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md font-medium transition-colors cursor-pointer" %>
    </div>
</div>
<% end %>
