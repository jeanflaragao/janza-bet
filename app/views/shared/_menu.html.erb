<nav class="bg-slate-900/80 backdrop-blur-md border-b border-white/5 sticky top-0 z-50" aria-label="Navegação principal">
    <div class="max-w-screen-lg mx-auto px-4">
        <div class="flex items-center justify-between h-14">
            <%# Logo %>
            <%= link_to root_path, class: "text-lg font-bold bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent tracking-tight shrink-0" do %>
                Janza Bet
            <% end %>

            <%# Nav links %>
            <ul class="hidden md:flex items-center gap-1 text-sm font-medium" role="list">
                <% nav_items = [
                     ["Home",           root_path],
                     ["Meses",          banks_path],
                     ["Casas",          books_path],
                     ["Transações",     transactions_path],
                     ["Balanço diário", daily_balances_path],
                   ] %>
                <% nav_items.each do |label, path| %>
                  <% active = current_page?(path) %>
                  <li>
                    <%= link_to label, path,
                          class: "px-3 py-1.5 rounded-lg transition-colors duration-150 #{active ? 'bg-indigo-500/15 text-indigo-300 font-semibold' : 'text-slate-400 hover:text-white hover:bg-white/5'}",
                          aria: { current: (active ? "page" : nil) } %>
                  </li>
                <% end %>
            </ul>

            <%# User actions %>
            <div class="flex items-center gap-2">
                <% if current_user %>
                  <span class="hidden sm:block text-xs text-slate-500 truncate max-w-[140px]"><%= current_user.email_address %></span>
                  <%= button_to session_path, method: :delete,
                        class: "flex items-center gap-1.5 text-sm text-slate-400 hover:text-red-400 hover:bg-red-400/10 px-3 py-1.5 rounded-lg transition-colors cursor-pointer" do %>
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                    </svg>
                    Sair
                  <% end %>
                <% else %>
                  <%= link_to "Entrar", new_session_path, class: "text-sm text-slate-400 hover:text-white px-3 py-1.5 rounded-lg hover:bg-white/5 transition-colors" %>
                <% end %>
            </div>
        </div>
    </div>
</nav>
