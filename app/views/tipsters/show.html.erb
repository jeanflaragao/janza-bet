<% content_for :title, "Showing tipster" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-emerald-500/15 mb-5 text-emerald-300 font-medium rounded-md inline-block border border-emerald-500/30" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl text-white mb-4">Tipster</h1>

  <%= render @tipster %>

  <%= link_to "Editar", edit_tipster_path(@tipster), class: "w-full sm:w-auto text-center inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-slate-800 border border-white/10 hover:bg-slate-700 text-slate-300 text-sm font-medium rounded-lg transition-colors" %>
  <%= link_to "Voltar", tipsters_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-slate-800 border border-white/10 hover:bg-slate-700 text-slate-300 text-sm font-medium rounded-lg transition-colors" %>
  <div class="sm:inline-block mt-2 sm:mt-0 sm:ml-2">
    <%= button_to "Excluir", @tipster, method: :delete, class: "w-full px-4 py-2.5 bg-red-600 hover:bg-red-500 text-white text-sm font-semibold rounded-lg cursor-pointer transition-colors", data: { turbo_confirm: "Tem certeza?" } %>
  </div>
</div>
