<div class="container mx-auto mt-10 px-5">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-white">Tipsters</h1>
        <%= link_to 'Novo Tipster', new_tipster_path, class: "inline-flex items-center gap-2 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-lg transition-colors" %>
    </div>

    <div class="bg-slate-800 rounded-xl overflow-hidden border border-white/10">
        <table class="w-full table-auto">
            <thead class="bg-slate-900">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider border-b border-white/10">Nome</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider border-b border-white/10">Status</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-slate-400 uppercase tracking-wider border-b border-white/10">Ações</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/10">
                <% @tipsters.each do |tipster| %>
                <tr class="hover:bg-slate-700/50 transition-colors">
                    <td class="px-4 py-3 text-slate-300"><%= tipster.name %></td>
                    <td class="px-4 py-3">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= tipster.status ? 'bg-emerald-500/20 text-emerald-300' : 'bg-slate-600/50 text-slate-400' %>">
                            <%= tipster.status ? 'Ativo' : 'Inativo' %>
                        </span>
                    </td>
                    <td class="px-4 py-3 text-right">
                        <%= link_to 'Ver', tipster, class: "text-sm font-medium text-indigo-400 hover:text-indigo-300 transition-colors" %>
                        <%= link_to 'Editar', edit_tipster_path(tipster), class: "ml-4 text-sm font-medium text-indigo-400 hover:text-indigo-300 transition-colors" %>
                        <%= button_to 'Excluir', tipster, method: :delete,
                              form: { data: { turbo_confirm: 'Excluir este tipster?' } },
                              class: "ml-4 text-sm font-medium text-red-400 hover:text-red-300 bg-transparent border-0 cursor-pointer transition-colors" %>
                    </td>
                </tr>
                <% end %>
            </tbody>
        </table>
    </div>
</div>