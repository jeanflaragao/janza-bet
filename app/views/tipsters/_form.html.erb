<%= form_with(model: tipster, class: "contents") do |form| %>
  <% if tipster.errors.any? %>
    <div id="error_explanation" class="bg-red-500/15 text-red-300 border border-red-500/30 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(tipster.errors.count, "error") %> prohibited this tipster from being saved:</h2>

      <ul class="list-disc ml-6">
        <% tipster.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :name, class: "block text-sm font-medium text-slate-300 mb-1" %>
    <%= form.text_field :name, class: ["block rounded-md border px-3 py-2 mt-2 w-full bg-slate-900 text-white placeholder-slate-500", {"border-white/10 focus:outline-indigo-600": tipster.errors[:name].none?, "border-red-400 focus:outline-red-600": tipster.errors[:name].any?}] %>
  </div>

  <div class="my-5 flex items-center gap-2">
    <%= form.label :status, class: "text-sm font-medium text-slate-300" %>
    <%= form.checkbox :status, class: ["block rounded-md border order-first h-5 w-5 bg-slate-900", {"border-white/10 focus:outline-indigo-600": tipster.errors[:status].none?, "border-red-400 focus:outline-red-600": tipster.errors[:status].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-lg inline-block cursor-pointer transition-colors" %>
  </div>
<% end %>
