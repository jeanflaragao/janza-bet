<%= form_with(model: bank, id: "form_bank", data: { turbo_frame: "_top" }, class: "space-y-6") do |form| %>
<% if bank.errors.any? %>
<div class="mb-4 p-3 bg-red-500/15 border border-red-500/30 rounded-md" role="alert">
    <p class="text-sm font-medium text-red-300 mb-1">Por favor corrija os erros abaixo:</p>
    <ul class="list-disc list-inside text-sm text-red-400 space-y-0.5">
        <% bank.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
        <% end %>
    </ul>
</div>
<% end %>

<div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    <div>
        <%= form.label :month, "Mês", class: "block text-sm font-medium text-slate-300 mb-1" %>
        <div class="relative rounded-md">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
            </div>
            <%= form.date_field :month,
                  class: "bg-slate-900 border border-white/10 text-white focus:ring-indigo-500 focus:border-indigo-500 block w-full pl-10 pr-3 py-2.5 rounded-md",
                  placeholder: "Selecione o mês" %>
        </div>
        <p class="mt-1 text-xs text-slate-500">Selecione o mês de referência</p>
    </div>

    <div>
        <%= form.label :bank_value, "Valor da banca", class: "block text-sm font-medium text-slate-300 mb-1" %>
        <div class="relative rounded-md">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <span class="text-slate-500 sm:text-sm">R$</span>
            </div>
            <%= form.number_field :bank_value,
                  step: 0.01,
                  class: "bg-slate-900 border border-white/10 text-white focus:ring-indigo-500 focus:border-indigo-500 block w-full pl-12 pr-3 py-2.5 rounded-md",
                  placeholder: "0,00" %>
        </div>
        <p class="mt-1 text-xs text-slate-500">Digite o valor com centavos</p>
    </div>
</div>

<div class="flex justify-end space-x-3 pt-4 border-t border-white/10">
    <% if bank.new_record? %>
    <button type="submit" class="inline-flex items-center gap-2 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-lg transition-colors">
        <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
        Salvar e voltar
    </button>
    <% end %>
</div>
<% end %>
