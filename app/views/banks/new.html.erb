<% content_for :title, "Novo mês" %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-slate-800 rounded-xl overflow-hidden border border-white/10">
        <div class="px-6 py-4 bg-slate-900 border-b border-white/10">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-2xl font-bold text-white">Criar mês</h1>
                </div>
                <div class="flex space-x-2">
                    <%= link_to banks_path, class: "inline-flex items-center gap-2 px-4 py-2.5 bg-slate-800 border border-white/10 hover:bg-slate-700 text-slate-300 text-sm font-medium rounded-lg transition-colors" do %>
                    <svg class="w-5 h-5 mr-2 -ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Voltar
                    <% end %>
                </div>
            </div>
        </div>

        <!-- Form content -->
        <div class="p-6">
            <%= render "form", bank: @bank %>
        </div>

    </div>
</div>