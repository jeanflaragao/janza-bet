<% content_for :title, "Editar Mês" %>

<div class="w-full">
    <div class="bg-slate-800 rounded-xl overflow-hidden border border-white/10">
        <!-- Cabeçalho com fundo escuro -->
        <div class="px-6 py-5 bg-slate-900 border-b border-white/10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <div class="flex items-center gap-3">
                        <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        <div>
                            <h1 class="text-2xl font-bold text-white"><%= l(@bank.month, format: "%B %Y") %></h1>
                            <div class="flex items-center gap-2 mt-1">
                                <span class="text-sm font-medium text-slate-400">Banca inicial</span>
                                <span class="text-xs px-2 py-1 bg-indigo-500/20 text-indigo-300 rounded-full"><%= number_to_currency(@amount_last_day_previous_month) %></span>
                                <span class="text-sm font-medium text-slate-400">Saldo em cash</span>
                                <span class="text-xs px-2 py-1 bg-indigo-500/20 text-indigo-300 rounded-full"><%= number_to_currency(@bank.cash_money) %></span>
                            </div>
                        </div>
                    </div>
                </div>
                <div>
                    <%= link_to banks_path, class: "inline-flex items-center gap-2 px-4 py-2.5 bg-slate-800 border border-white/10 hover:bg-slate-700 text-slate-300 text-sm font-medium rounded-lg transition-colors" do %>
                    <svg class="w-5 h-5 mr-2 -ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Voltar
                    <% end %>
                </div>
            </div>
        </div>

        <!-- Cards de Estatísticas - Layout expansivo -->
        <div class="grid grid-cols-4 sm:grid-cols-4 lg:grid-cols-4 xl:grid-cols-4 gap-6 p-6">
            <!-- Card de Depósitos -->
            <div class="bg-slate-800 border border-white/10 rounded-xl p-5 hover:border-white/20 transition-all duration-300">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-slate-400">Depósitos</p>
                        <p class="text-2xl font-bold text-white mt-1"><%= number_to_currency(@bank.total_deposits) %></p>
                    </div>
                    <div class="p-3 rounded-full bg-red-500/15 text-red-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Card de Saques -->
            <div class="bg-slate-800 border border-white/10 rounded-xl p-5 hover:border-white/20 transition-all duration-300">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-slate-400">Saques</p>
                        <p class="text-2xl font-bold text-white mt-1"><%= number_to_currency(@bank.total_withdrawals) %></p>
                    </div>
                    <div class="p-3 rounded-full bg-indigo-500/15 text-indigo-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Card de Saldo em Contas -->
            <div class="bg-slate-800 border border-white/10 rounded-xl p-5 hover:border-white/20 transition-all duration-300">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-slate-400">Saldo em contas</p>
                        <p class="text-2xl font-bold <%= @bank.total_balance.negative? ? 'text-red-400' : 'text-emerald-400' %> mt-1">
                            <%= number_to_currency(@bank.total_balance) %>
                        </p>
                    </div>
                    <div class="p-3 rounded-full bg-emerald-500/15 text-emerald-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Card de Lucro -->
            <div class="bg-slate-800 border border-white/10 rounded-xl p-5 hover:border-white/20 transition-all duration-300">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-slate-400">Lucro</p>
                        <% 
                profit = @cumulative_profits.last[1]
                profit_class = profit.negative? ? 'text-red-400' : 'text-emerald-400'
              %>
                        <p class="text-2xl font-bold <%= profit_class %> mt-1">
                            <%= number_to_currency(profit) %>
                        </p>
                    </div>
                    <div class="p-3 rounded-full bg-purple-500/15 text-purple-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                    </div>
                </div>
            </div>

        </div>

        <!-- Seção do Gráfico de Lucro Cumulativo -->
        <div class="p-6 border-t border-white/10">
            <h2 class="text-lg font-semibold text-white mb-4">Lucro Acumulado no Mês</h2>
            <div class="bg-slate-900 p-4 rounded-lg border border-white/10">
                <% if @cumulative_profits.present? %>
                <%= line_chart @cumulative_profits, height: "300px", colors: ["#818cf8"]%>
                <% else %>
                <p class="text-slate-400">Nenhum dado disponível para exibir o gráfico.</p>
                <% end %>
            </div>
        </div>

        <!-- Rodapé com ações -->
        <div class="px-6 py-4 bg-slate-900 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4">
            <div class="text-sm text-slate-400">
                Última atualização: <%= time_ago_in_words(@bank.updated_at) %> atrás
            </div>
            <div class="flex space-x-3">
                <%= button_to "Excluir", @bank, method: :delete, data: { confirm: "Tem certeza que deseja excluir esta banca?" }, class: "px-4 py-2.5 bg-red-600 hover:bg-red-500 text-white text-sm font-semibold rounded-lg transition-colors cursor-pointer" %>
            </div>
        </div>
    </div>
</div>