<tr id="<%= dom_id(book) %>" class="hover:bg-slate-700/50 text-sm transition-all duration-150">
    <td class="px-6 py-4 whitespace-nowrap text-white font-medium"><%= book.owner %></td>

    <td class="px-6 py-4">
        <div class="text-sm text-white font-medium truncate max-w-[180px]" title="<%= book.name %>">
            <%= book.name %>
        </div>
        <div class="text-xs text-slate-500 mt-0.5">ID: <%= book.id %></div>
    </td>

    <td class="hidden md:table-cell px-6 py-4 text-sm text-slate-400 italic"><%= book.description %></td>

    <td class="px-6 py-4 whitespace-nowrap">
        <% if book.inactive? %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-600/50 text-slate-400">
            Inativa
        </span>
        <% else %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-500/20 text-emerald-300">
            Ativa
        </span>
        <% end %>
    </td>

    <td class="px-6 py-4 whitespace-nowrap text-right">
        <div class="flex justify-end items-center gap-3">
            <% if action_name != "show" %>
            <%= link_to edit_book_path(book),
                  class: "p-1.5 text-slate-500 hover:text-indigo-400 hover:bg-indigo-500/10 rounded-full transition-colors",
                  aria: { label: "Editar #{book.name}" } do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M16.732 3.732a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
            </svg>
            <% end %>

            <%= button_to book_path(book), method: :delete,
                  form: { data: { turbo_confirm: "Excluir #{book.name}?" } },
                  class: "p-1.5 text-slate-500 hover:text-red-400 hover:bg-red-500/10 rounded-full transition-colors",
                  aria: { label: "Excluir #{book.name}" } do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
            </svg>
            <% end %>
            <% end %>

            <div data-controller="modal">
                <button data-action="click->modal#open"
                        class="p-1.5 text-slate-500 hover:text-indigo-400 hover:bg-indigo-500/10 rounded-full transition-colors"
                        aria-label="Ver transações de <%= book.name %>">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                </button>

                <dialog data-modal-target="dialog" class="fixed inset-0 z-50 flex items-center justify-center p-4 opacity-0 invisible transition-opacity duration-300"
                        aria-label="Transações de <%= book.name %>" role="dialog" aria-modal="true">
                    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" data-action="click->modal#close"></div>
                    <div class="relative w-full max-w-4xl max-h-[90vh] bg-slate-800 rounded-xl shadow-2xl overflow-hidden transform transition-all">
                        <div class="flex items-center justify-between p-6 border-b border-white/10 bg-slate-900">
                            <h3 class="text-xl font-semibold text-white">
                                <span class="text-indigo-400 font-bold">#<%= book.id %></span> <%= book.description %>
                            </h3>
                            <button data-action="modal#close"
                                    class="p-1.5 text-slate-400 hover:text-white hover:bg-white/10 rounded-full transition-colors"
                                    aria-label="Fechar modal">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                </svg>
                            </button>
                        </div>
                        <div class="overflow-y-auto max-h-[calc(90vh-130px)]">
                            <table class="min-w-full divide-y divide-white/10">
                                <thead class="bg-slate-900 sticky top-0">
                                    <tr>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">Data</th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">Tipo</th>
                                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-slate-400 uppercase tracking-wider">Valor</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-slate-800 divide-y divide-white/10">
                                    <% book.transactions.sort_by(&:date).each do |txn| %>
                                    <tr class="hover:bg-slate-700/50 transition-colors duration-150">
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-300">
                                            <%= txn.date.strftime("%d/%m/%Y") %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <span class="px-3 py-1 text-xs font-semibold rounded-full <%= txn.transaction_type == 'deposit' ? 'bg-red-500/20 text-red-300' : 'bg-emerald-500/20 text-emerald-300' %>">
                                                <%= txn.transaction_type == 'deposit' ? 'Depósito' : 'Saque' %>
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-right <%= txn.transaction_type == 'deposit' ? 'text-red-400' : 'text-emerald-400' %>">
                                            <%= number_to_currency(txn.amount, unit: "R$ ", separator: ",", delimiter: ".") %>
                                        </td>
                                    </tr>
                                    <% end %>
                                    <% if book.transactions.empty? %>
                                    <tr>
                                        <td colspan="3" class="px-6 py-8 text-center text-sm text-slate-500">Nenhuma transação registrada.</td>
                                    </tr>
                                    <% end %>
                                </tbody>
                            </table>
                        </div>
                        <div class="flex items-center justify-between p-4 border-t border-white/10 bg-slate-900">
                            <span class="text-sm text-slate-500"><%= book.transactions.size %> transações</span>
                            <button data-action="modal#close"
                                    class="px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-lg transition-colors cursor-pointer">
                                Fechar
                            </button>
                        </div>
                    </div>
                </dialog>
            </div>
        </div>
    </td>
</tr>
