<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
        <h1 class="text-3xl font-bold text-white">Casas de Apostas</h1>
        <div class="bg-indigo-500/15 px-4 py-2 rounded-lg border border-indigo-500/20">
            <p class="text-sm text-indigo-300">Total: <%= @books.size %> casas</p>
        </div>
    </div>

    <div class="bg-slate-800 rounded-xl overflow-hidden mb-8 border border-white/10">
        <div class="px-6 py-4 bg-slate-900 border-b border-white/10">
            <h2 class="text-lg font-semibold text-white">Adicione uma casa</h2>
        </div>
        <div class="p-6">
            <%= turbo_frame_tag "new-book-form", src: new_book_path, class: "w-full" %>
        </div>
    </div>

    <div class="bg-slate-800 rounded-xl overflow-hidden border border-white/10">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-white/10">
                <thead class="bg-slate-900">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Dono</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Casa de Aposta</th>
                        <th scope="col" class="hidden md:table-cell px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Apelido</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Status</th>
                        <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-slate-400 uppercase tracking-wider">Ações</th>
                    </tr>
                </thead>
                <tbody id="books" class="bg-slate-800 divide-y divide-white/10">
                    <% if @books.any? %>
                    <%= render @books %>
                    <% else %>
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mx-auto text-gray-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                            </svg>
                            <p class="text-sm text-slate-500">Nenhuma casa encontrada. Crie a sua primeira usando o formulário acima.</p>
                        </td>
                    </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </div>
</div>
