<% content_for :title, "Editar Book" %>

<div class="w-full">
    <div class="bg-slate-800 rounded-xl overflow-hidden border border-white/10">
        <!-- Cabeçalho escuro -->
        <div class="px-6 py-5 bg-slate-900 border-b border-white/10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <div class="flex items-center gap-3">
                        <div>
                            <h1 class="text-2xl font-bold text-white"><%= @book.description %></h1>
                            <div class="flex items-center gap-2 mt-1">
                                <span class="text-sm font-medium text-slate-400">Situação:</span>
                                <span class="text-xs px-2 py-1 <%= @book.inactive? ? 'bg-slate-600/50 text-slate-400' : 'bg-emerald-500/20 text-emerald-300' %> rounded-full">
                                    <div class="flex justify-start">
                                        <% if @book.inactive? %>
                                        Inativada
                                        <% else %>
                                        Ativo
                                        <% end %>
                                    </div>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
                <div>
                    <%= link_to books_path, class: "inline-flex items-center gap-2 px-4 py-2.5 bg-slate-800 border border-white/10 hover:bg-slate-700 text-slate-300 text-sm font-medium rounded-lg transition-colors" do %>
                    <svg class="w-5 h-5 mr-2 -ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Voltar
                    <% end %>
                </div>
            </div>
        </div>

        <!-- Cards de Estatísticas -->
        <div class="grid grid-cols-4 sm:grid-cols-4 lg:grid-cols-4 xl:grid-cols-4 gap-6 p-6">
            <!-- Card de Depósitos -->
            <div class="bg-slate-800 border border-white/10 rounded-xl p-5 hover:border-white/20 transition-all duration-300">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-slate-400">Depósitos</p>
                        <p class="text-2xl font-bold text-white mt-1"><%= number_to_currency(@total_deposit) %></p>
                    </div>
                    <div class="p-3 rounded-full bg-red-500/15 text-red-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Card de Saques -->
            <div class="bg-slate-800 border border-white/10 rounded-xl p-5 hover:border-white/20 transition-all duration-300">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-slate-400">Saques</p>
                        <p class="text-2xl font-bold text-white mt-1"><%= number_to_currency( @total_withdraw) %></p>
                    </div>
                    <div class="p-3 rounded-full bg-indigo-500/15 text-indigo-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Card de Saldo em Contas -->
            <div class="bg-slate-800 border border-white/10 rounded-xl p-5 hover:border-white/20 transition-all duration-300">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-slate-400">Saldo atual</p>
                        <p class="text-2xl font-bold <%=@last_daily_balance.negative? ? 'text-red-400' : 'text-emerald-400' %> mt-1">
                            <%= number_to_currency(@last_daily_balance) %>
                        </p>
                    </div>
                    <div class="p-3 rounded-full bg-emerald-500/15 text-emerald-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Card de Lucro -->
            <div class="bg-slate-800 border border-white/10 rounded-xl p-5 hover:border-white/20 transition-all duration-300">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-slate-400">Lucro</p>
                        <% 
                            profit_class = @total_profit.negative? ? 'text-red-400' : 'text-emerald-400'
                        %>
                        <p class="text-2xl font-bold <%= profit_class %> mt-1">
                            <%= number_to_currency(@total_profit) %>
                        </p>
                    </div>
                    <div class="p-3 rounded-full bg-purple-500/15 text-purple-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                    </div>
                </div>
            </div>
        </div>
        <!-- Seção do Gráfico de Lucro Cumulativo -->
        <div class="p-6 border-t border-white/10">
            <h2 class="text-lg font-semibold text-white mb-4">Lucro Acumulado na casa</h2>
            <div class="bg-slate-900 p-4 rounded-lg border border-white/10">
                <% if @accumulated_profit.present? %>
                <%= line_chart @accumulated_profit,
    height: "300px",
    colors: ["#818cf8"],
    library: {
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            callback: "function(value) { return 'R$ ' + value.toFixed(2).replace('.', ','); }"
          }
        }
      },
      plugins: {
        annotation: {
          annotations: {
            zeroLine: {
              type: 'line',
              yMin: 0,
              yMax: 0,
              borderColor: '#475569',
              borderWidth: 1,
              borderDash: [6, 6],
              label: {
                content: 'Linha Zero',
                enabled: true,
                position: 'right',
                backgroundColor: 'rgba(0,0,0,0.3)'
              }
            }
          }
        }
      },
      tooltips: {
        callbacks: {
          label: "function(item) { return 'Lucro Acumulado: R$ ' + item.yLabel.toFixed(2).replace('.', ','); }"
        }
      }
    } %>
                <% else %>
                <p class="text-slate-400">Nenhum dado disponível para exibir o gráfico.</p>
                <% end %>
            </div>
        </div>
    </div>
</div>