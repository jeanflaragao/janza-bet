<%# Define the colors based on profit %>
<% text_color = @profit_total >= 0 ? 'emerald' : 'red' %>

<div class="flex justify-end gap-2 mb-4 flex-wrap">
    <%= link_to "Mês anterior", root_path(filter: "last_month"), class: "px-3 py-1.5 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-300 text-sm border border-white/10 transition-colors" %>
    <%= link_to "Mês atual",    root_path(filter: "month"),      class: "px-3 py-1.5 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-300 text-sm border border-white/10 transition-colors" %>
    <%= link_to "Tudo",         root_path(filter: "all_time"),   class: "px-3 py-1.5 rounded-lg bg-indigo-500/20 hover:bg-indigo-500/30 text-indigo-300 text-sm border border-indigo-500/30 transition-colors" %>
</div>

<div class="flex flex-wrap gap-4 mb-6 pt-2">
    <div class="flex-1 min-w-[180px] bg-slate-800 border border-white/10 rounded-xl p-4">
        <div class="text-xs font-medium text-slate-400 mb-1">Depósitos</div>
        <div class="text-2xl font-bold text-white mt-1"><%= number_to_currency(@total_deposits) %></div>
    </div>
    <div class="flex-1 min-w-[180px] bg-slate-800 border border-white/10 rounded-xl p-4">
        <div class="text-xs font-medium text-slate-400 mb-1">Saques</div>
        <div class="text-2xl font-bold text-white mt-1"><%= number_to_currency(@total_withdrawals) %></div>
    </div>
    <div class="flex-1 min-w-[180px] bg-slate-800 border border-white/10 rounded-xl p-4">
        <div class="text-xs font-medium text-slate-400 mb-1">Saldo em contas</div>
        <div class="text-2xl font-bold text-emerald-400 mt-1"><%= number_to_currency(@last_balance) %></div>
    </div>
    <div class="flex-1 min-w-[180px] bg-slate-800 border border-white/10 rounded-xl p-4">
        <div class="text-xs font-medium text-slate-400 mb-1">Lucro total</div>
        <div class="text-2xl font-bold text-<%= text_color %>-400 mt-1"><%= number_to_currency(@profit_total) %></div>
    </div>
</div>

<div class="bg-slate-800 border border-white/10 rounded-xl p-4 mb-6">
    <% if @daily_balances.present? %>
    <%= line_chart @daily_balances.group_by_day(:date).sum(:balance), library: { height: "300px" }, colors: ["#818cf8"] %>
    <% else %>
    <p class="text-slate-500 text-sm">Nenhum dado de saldo disponível.</p>
    <% end %>
</div>

<div class="bg-slate-800 border border-white/10 rounded-xl p-4 mb-6">
    <h3 class="text-sm font-medium text-slate-400 mb-4">Distribuição da banca por casa</h3>
    <% if @balances_by_book.present? %>
    <%= pie_chart @balances_by_book, library: { height: "300px" } %>
    <% else %>
    <p class="text-slate-500 text-sm">Nenhum dado disponível.</p>
    <% end %>
</div>
