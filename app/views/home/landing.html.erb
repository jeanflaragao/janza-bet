<div class="min-h-screen bg-slate-950 text-white">

  <%# ─── Navigation ──────────────────────────────────────────────────────── %>
  <nav class="fixed top-0 inset-x-0 z-50 bg-slate-950/80 backdrop-blur-md border-b border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <span class="text-xl font-bold bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent tracking-tight">
        Janza Bet
      </span>

      <div class="hidden md:flex items-center gap-8 text-sm text-slate-400">
        <a href="#features" class="hover:text-white transition-colors">Funcionalidades</a>
        <a href="#how"      class="hover:text-white transition-colors">Como funciona</a>
        <a href="#stats"    class="hover:text-white transition-colors">Números</a>
      </div>

      <div class="flex items-center gap-3">
        <%= link_to "Entrar", new_session_path,
              class: "text-sm text-slate-300 hover:text-white transition-colors px-4 py-2" %>
        <%= link_to "Começar grátis", new_registration_path,
              class: "text-sm bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg px-4 py-2 font-medium transition-colors shadow-lg shadow-indigo-600/20" %>
      </div>
    </div>
  </nav>

  <%# ─── Hero ───────────────────────────────────────────────────────────── %>
  <section class="relative pt-36 pb-28 overflow-hidden">
    <%# Ambient glows %>
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute -top-48 -left-48 w-[500px] h-[500px] bg-indigo-600/20 rounded-full blur-3xl"></div>
      <div class="absolute top-10 right-0  w-[600px] h-[600px] bg-violet-600/15 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[700px] h-48 bg-indigo-800/20 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/20 rounded-full px-4 py-1.5 text-sm text-indigo-300 mb-8">
        <span class="w-2 h-2 rounded-full bg-indigo-400 animate-pulse inline-block"></span>
        Gestão profissional de apostas esportivas
      </div>

      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.1] mb-6">
        Controle sua banca.<br>
        <span class="bg-gradient-to-r from-indigo-400 via-violet-400 to-purple-400 bg-clip-text text-transparent">
          Maximize seus lucros.
        </span>
      </h1>

      <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
        Registre apostas, monitore tipsters, acompanhe seu saldo em tempo real
        e tome decisões baseadas em dados — tudo em um só lugar.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <%= link_to new_registration_path,
              class: "group flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white rounded-xl px-8 py-4 text-base font-semibold transition-all shadow-xl shadow-indigo-600/25" do %>
          Começar gratuitamente
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        <% end %>
        <a href="#features"
           class="flex items-center gap-2 text-slate-300 hover:text-white border border-white/10 hover:border-white/25 rounded-xl px-8 py-4 text-base font-semibold transition-all">
          Ver funcionalidades
        </a>
      </div>

      <%# ── Dashboard mockup ── %>
      <div class="mt-20 relative">
        <div class="bg-slate-800/40 backdrop-blur border border-white/10 rounded-2xl p-1 shadow-2xl shadow-black/60 max-w-5xl mx-auto">
          <div class="bg-slate-900 rounded-xl overflow-hidden">

            <%# Browser chrome %>
            <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5 bg-slate-900/80">
              <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
              <div class="ml-4 flex-1 bg-slate-800 rounded-md px-3 py-1 text-xs text-slate-500 text-left">
                app.janzabet.com/dashboard
              </div>
            </div>

            <%# KPI cards %>
            <div class="p-6 grid grid-cols-2 md:grid-cols-4 gap-3">
              <div class="bg-slate-800 rounded-xl p-4 border border-white/5">
                <div class="text-xs text-slate-500 mb-1">Lucro do mês</div>
                <div class="text-2xl font-bold text-emerald-400">+R$ 1.847</div>
                <div class="text-xs text-emerald-500/80 mt-1">▲ 12% vs mês anterior</div>
              </div>
              <div class="bg-slate-800 rounded-xl p-4 border border-white/5">
                <div class="text-xs text-slate-500 mb-1">ROI</div>
                <div class="text-2xl font-bold text-indigo-400">+8,3%</div>
                <div class="text-xs text-indigo-400/70 mt-1">▲ 2,1 p.p. vs anterior</div>
              </div>
              <div class="bg-slate-800 rounded-xl p-4 border border-white/5">
                <div class="text-xs text-slate-500 mb-1">Apostas</div>
                <div class="text-2xl font-bold text-white">142</div>
                <div class="text-xs text-slate-400/70 mt-1">62% win rate</div>
              </div>
              <div class="bg-slate-800 rounded-xl p-4 border border-white/5">
                <div class="text-xs text-slate-500 mb-1">Banca total</div>
                <div class="text-2xl font-bold text-violet-400">R$ 24.500</div>
                <div class="text-xs text-slate-400/70 mt-1">8 casas ativas</div>
              </div>
            </div>

            <%# Chart bars %>
            <div class="px-6 pb-6">
              <div class="bg-slate-800 rounded-xl p-5 border border-white/5">
                <div class="flex items-center justify-between mb-4">
                  <div class="text-xs text-slate-400 font-medium">Evolução da banca — Abril 2026</div>
                  <div class="text-xs text-emerald-400 font-semibold">+22% no período</div>
                </div>
                <div class="flex items-end gap-1 h-24">
                  <% [38,45,42,58,55,62,60,72,68,75,74,82,80,90,88,95,92,100].each_with_index do |h, i| %>
                    <div class="flex-1 rounded-sm opacity-<%= i < 9 ? '50' : '90' %>"
                         style="height:<%= h %>%; background:linear-gradient(to top,#6366f1,#8b5cf6)"></div>
                  <% end %>
                </div>
              </div>
            </div>

          </div>
        </div>
        <%# Glow under mockup %>
        <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 w-2/3 h-20 bg-indigo-600/20 blur-3xl pointer-events-none"></div>
      </div>
    </div>
  </section>

  <%# ─── Features ───────────────────────────────────────────────────────── %>
  <section id="features" class="py-24 bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          Tudo que você precisa para apostar com disciplina
        </h2>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">
          Do registro da aposta à análise de performance — sem planilhas, sem confusão.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        <% [
          { color: "indigo",   icon: "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z",
            title: "Gestão de Banca",        desc: "Controle o saldo em cada casa de apostas com visão consolidada do seu patrimônio total." },
          { color: "violet",   icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2",
            title: "Registro de Apostas",    desc: "Cadastre cada aposta com odds, stake, mercado e resultado. Histórico completo e pesquisável." },
          { color: "emerald",  icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",
            title: "Tipsters",               desc: "Avalie o desempenho dos tipsters que você segue — ROI, taxa de acerto e histórico detalhado." },
          { color: "blue",     icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
            title: "Gráficos e Analytics",   desc: "Visualize a evolução da sua banca com gráficos interativos. Identifique padrões e tendências." },
          { color: "orange",   icon: "M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4",
            title: "Depósitos e Saques",     desc: "Registre todas as movimentações financeiras entre casas e sua conta. Zero confusão." },
          { color: "pink",     icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
            title: "Saldo Diário",           desc: "Registre o saldo ao final de cada dia e acompanhe a curva de crescimento da banca." },
        ].each do |f| %>
          <div class="group bg-slate-800/40 hover:bg-slate-800 border border-white/5 hover:border-<%= f[:color] %>-500/30 rounded-2xl p-6 transition-all duration-200">
            <div class="w-11 h-11 bg-<%= f[:color] %>-500/15 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-<%= f[:color] %>-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="<%= f[:icon] %>"/>
              </svg>
            </div>
            <h3 class="text-base font-semibold mb-2"><%= f[:title] %></h3>
            <p class="text-slate-400 text-sm leading-relaxed"><%= f[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%# ─── How it works ────────────────────────────────────────────────────── %>
  <section id="how" class="py-24 bg-slate-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Simples de usar, poderoso nos resultados</h2>
        <p class="text-slate-400 text-lg">Comece em menos de 5 minutos.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-10 relative">
        <div class="hidden md:block absolute top-8 left-[18%] right-[18%] h-px bg-gradient-to-r from-indigo-500/0 via-indigo-500/40 to-indigo-500/0"></div>

        <% [
          { n: "1", color: "indigo",  title: "Crie sua conta",
            desc: "Cadastro gratuito em segundos. Sem cartão de crédito necessário." },
          { n: "2", color: "violet",  title: "Configure suas casas",
            desc: "Adicione as casas onde você aposta e defina o saldo inicial de cada uma." },
          { n: "3", color: "purple",  title: "Acompanhe o crescimento",
            desc: "Registre apostas e veja sua banca evoluir com gráficos em tempo real." },
        ].each do |s| %>
          <div class="text-center">
            <div class="w-16 h-16 bg-<%= s[:color] %>-600 rounded-2xl flex items-center justify-center mx-auto mb-6 text-2xl font-bold shadow-xl shadow-<%= s[:color] %>-600/30">
              <%= s[:n] %>
            </div>
            <h3 class="text-xl font-semibold mb-3"><%= s[:title] %></h3>
            <p class="text-slate-400"><%= s[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%# ─── Stats ───────────────────────────────────────────────────────────── %>
  <section id="stats" class="py-20 bg-gradient-to-r from-indigo-900 via-violet-900 to-indigo-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <% [
          { value: "+500",  label: "Apostadores ativos" },
          { value: "50k+",  label: "Apostas registradas" },
          { value: "R$2M+", label: "Volume gerenciado" },
          { value: "100%",  label: "Gratuito para começar" },
        ].each do |s| %>
          <div>
            <div class="text-4xl font-extrabold text-white mb-1"><%= s[:value] %></div>
            <div class="text-indigo-300 text-sm"><%= s[:label] %></div>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%# ─── CTA ─────────────────────────────────────────────────────────────── %>
  <section class="py-28 bg-slate-900">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">
        Pronto para apostar<br>
        <span class="bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent">
          com mais inteligência?
        </span>
      </h2>
      <p class="text-slate-400 text-lg mb-10">
        Junte-se a centenas de apostadores que já controlam sua banca com Janza Bet.
      </p>
      <%= link_to new_registration_path,
            class: "inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white rounded-xl px-10 py-4 text-lg font-semibold transition-all shadow-xl shadow-indigo-600/30" do %>
        Criar conta grátis
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      <% end %>
    </div>
  </section>

  <%# ─── Footer ─────────────────────────────────────────────────────────── %>
  <footer class="border-t border-white/5 py-10 bg-slate-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <span class="text-xl font-bold bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent">
          Janza Bet
        </span>
        <div class="flex gap-6 text-sm text-slate-500">
          <a href="#features" class="hover:text-slate-300 transition-colors">Funcionalidades</a>
          <a href="#how"      class="hover:text-slate-300 transition-colors">Como funciona</a>
          <%= link_to "Entrar",    new_session_path,      class: "hover:text-slate-300 transition-colors" %>
          <%= link_to "Cadastrar", new_registration_path, class: "hover:text-slate-300 transition-colors" %>
        </div>
        <div class="text-sm text-slate-600">© 2026 Janza Bet. Todos os direitos reservados.</div>
      </div>
    </div>
  </footer>

</div>
