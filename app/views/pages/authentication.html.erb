<div class="flex items-center justify-center py-12">
  <div class="bg-slate-800 rounded-xl p-8 max-w-lg mx-auto border border-white/10 w-full">
    <h1 class="font-bold text-4xl text-white text-center mb-6">Autenticação</h1>
  
    <div class="text-center space-y-4">
      <% if current_user %>
        <p class="text-lg text-slate-300 font-semibold">Bem-vindo, <%= current_user.email_address %>!</p>

        <!-- Show confirmation status -->
        <% if current_user.respond_to?(:confirmed?) && !current_user.confirmed? %>
          <p class="text-lg text-amber-400 font-semibold">Confirme seu e-mail para acesso completo.</p>
        <% end %>

        <%= link_to "Sair", session_path, 
            method: :delete, 
            data: { turbo_method: :delete, confirm: "Tem certeza?" }, 
            class: "bg-red-600 hover:bg-red-500 text-white font-bold py-2 px-4 rounded-md transition duration-200" %>
      <% else %>
        <p class="text-lg text-slate-300">Por favor, entre para acessar mais funcionalidades.</p>
        <%= link_to "Entrar", new_session_path, 
            class: "bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-2 px-4 rounded-md transition duration-200" %>
      <% end %>

      <div class="mt-6 text-left">
        <h2 class="text-2xl font-semibold text-white mb-4">Links Úteis:</h2>
        <ul class="space-y-3">
          
          <% if current_user %>
            <!-- Show links when user is signed in -->
            <li>
              <%= link_to "Sair", session_path, method: :delete, data: { turbo_method: :delete, confirm: "Tem certeza?" }, class: "text-indigo-400 hover:text-indigo-300 hover:underline" %>
            </li>
          <% else %>
            <!-- Show links when user is signed out -->
            <li>
              <%= link_to "Registrar Novo Usuário", new_registration_path, class: "text-indigo-400 hover:text-indigo-300 hover:underline" %>
            </li>
            <li>
              <%= link_to "Entrar", new_session_path, class: "text-indigo-400 hover:text-indigo-300 hover:underline" %>
            </li>
          <% end %>

          <!-- Forgot Password link is available for both signed in and signed out users -->
          <li>
            <%= link_to "Esqueci a senha", new_password_path, class: "text-indigo-400 hover:text-indigo-300 hover:underline" %>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>
