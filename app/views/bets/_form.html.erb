<%= form_with(model: bet, id: "form_bet") do |form| %>
<div class="bg-slate-800 border border-white/10 rounded-lg p-6 mb-6">
    <% if bet.errors.any? %>
    <div class="mb-4 p-3 bg-red-500/15 border border-red-500/30 rounded-md" role="alert">
        <p class="text-sm font-medium text-red-300 mb-1">Por favor corrija os erros abaixo:</p>
        <ul class="list-disc list-inside text-sm text-red-400 space-y-0.5">
            <% bet.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
            <% end %>
        </ul>
    </div>
    <% end %>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div>
            <%= form.label :event_date, "Data do evento", class: "block text-sm font-medium text-slate-300 mb-1" %>
            <%= form.date_field :event_date, class: "bg-slate-900 border border-white/10 text-white p-2 w-full rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
        <div>
            <%= form.label :game, "Jogo", class: "block text-sm font-medium text-slate-300 mb-1" %>
            <%= form.text_field :game, placeholder: "Ex: Flamengo x Corinthians", class: "bg-slate-900 border border-white/10 text-white placeholder-slate-500 p-2 w-full rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
        <div>
            <%= form.label :bet, "Aposta", class: "block text-sm font-medium text-slate-300 mb-1" %>
            <%= form.text_field :bet, placeholder: "Ex: 1X2 Casa", class: "bg-slate-900 border border-white/10 text-white placeholder-slate-500 p-2 w-full rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
        <div>
            <%= form.label :stake, "Stake", class: "block text-sm font-medium text-slate-300 mb-1" %>
            <%= form.number_field :stake, step: 0.01, placeholder: "0.00", class: "bg-slate-900 border border-white/10 text-white placeholder-slate-500 p-2 w-full rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
        <div>
            <%= form.label :odd, "Odd", class: "block text-sm font-medium text-slate-300 mb-1" %>
            <%= form.number_field :odd, step: 0.01, placeholder: "1.00", class: "bg-slate-900 border border-white/10 text-white placeholder-slate-500 p-2 w-full rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
        <div>
            <%= form.label :status, "Status", class: "block text-sm font-medium text-slate-300 mb-1" %>
            <%= form.select :status, Bet::STATUSES, { prompt: "Selecione" }, class: "bg-slate-900 border border-white/10 text-white p-2 w-full rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
        <div>
            <%= form.label :book_id, "Casa", class: "block text-sm font-medium text-slate-300 mb-1" %>
            <%= form.collection_select :book_id, current_user.books.order(:description), :id, :description, { prompt: "Selecione" }, class: "bg-slate-900 border border-white/10 text-white p-2 w-full rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
        <div>
            <%= form.label :tipster_id, "Tipster", class: "block text-sm font-medium text-slate-300 mb-1" %>
            <%= form.collection_select :tipster_id, Tipster.all, :id, :name, { prompt: "Selecione" }, class: "bg-slate-900 border border-white/10 text-white p-2 w-full rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
    </div>

    <div class="mt-4 text-right">
        <%= form.submit "Salvar", class: "px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-lg transition-colors cursor-pointer" %>
    </div>
</div>
<% end %>
