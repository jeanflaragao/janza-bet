<%= turbo_frame_tag balance do %>
<%= form_with(model: balance, 
                url: daily_balance_path(balance), 
                method: :patch, 
                data: { turbo_frame: dom_id(balance) }, 
                class: "balance-form") do |f| %>

<div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center p-4 bg-slate-800 rounded-lg border border-white/10 hover:border-white/20 transition-all duration-200">

    <!-- Book Information -->
    <div class="flex-1 min-w-0">
        <h3 class="text-base font-semibold text-slate-300 truncate">
            <%= balance.book.description %>
        </h3>
    </div>

    <!-- Balance Input -->
    <div class="w-full sm:w-32">
        <div class="relative">
            <%= f.label :balance, "Total", class: "sr-only" %>
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <span class="text-slate-500">$</span>
            </div>
            <%= f.number_field :balance, 
                step: "0.01",
                class: "block w-full pl-7 pr-12 py-2 bg-slate-900 border border-white/10 rounded-md focus:ring-indigo-500 focus:border-indigo-500 text-sm text-white",
                placeholder: "0.00" %>
            <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                <span class="text-slate-500 text-xs">R$</span>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex gap-2 w-full sm:w-auto">
        <%= f.submit "Salvar", 
              class: "flex-1 sm:flex-none px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-lg transition-colors cursor-pointer" %>
    </div>

</div>
<% end %>
<% end %>