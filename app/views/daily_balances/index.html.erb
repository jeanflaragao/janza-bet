<div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <!-- Generate Form Card -->
    <div class="bg-slate-800 rounded-xl p-6 mb-8 border border-white/10">
        <h2 class="text-xl font-semibold text-white mb-4">Gerar balanço diário</h2>
        <%= form_with url: add_for_date_daily_balances_path, method: :post, class: "flex flex-col sm:flex-row gap-4 items-start sm:items-end" do %>
        <div class="flex-1 flex-col w-full">
            <label for="date" class="block text-sm font-medium text-slate-300 mb-1">Selecione a data</label>
            <div class="relative rounded-md">
                <%= date_field_tag :date, Date.today, class: "block w-full rounded-md bg-slate-900 border border-white/10 py-2 pl-3 pr-10 focus:border-indigo-500 focus:ring-indigo-500 text-sm text-white", placeholder: "Select date" %>
            </div>
        </div>
        <div>
            <%= submit_tag "Gerar", class: "px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-lg transition-colors cursor-pointer" %>
        </div>
        <% end %>
    </div>

    <!-- Summary Table Card -->
    <div class="bg-slate-800 rounded-xl overflow-hidden border border-white/10">
        <div class="px-6 py-4 border-b border-white/10 flex justify-between items-center">
            <h2 class="text-xl font-semibold text-white">Resumo balanço diário</h2>
            <span class="text-sm text-slate-400"><%= @date_summaries.count %> registros</span>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-white/10">
                <thead class="bg-slate-900">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">Data</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">Total Books</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">Books zerados</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">Total</th>
                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-slate-400 uppercase tracking-wider">Acões</th>
                    </tr>
                </thead>
                <tbody class="bg-slate-800 divide-y divide-white/10">
                    <% @date_summaries.each do |summary| %>
                    <tr class="hover:bg-slate-700/50 transition-colors duration-150">
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-white">
                            <%= summary[:date] %>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-500/20 text-indigo-300">
                                <%= summary[:total_books] %>
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <% if summary[:books_with_zero_balance] > 0 %>
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-500/20 text-red-300">
                                <%= summary[:books_with_zero_balance] %>
                            </span>
                            <% else %>
                            <span class="text-slate-500">-</span>
                            <% end %>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-500/20 text-indigo-300">
                                <%= summary[:total_balance] %>
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                            <%= link_to edit_by_date_daily_balances_path(date: summary[:date]), class: "text-sm font-medium text-indigo-400 hover:text-indigo-300 mr-4 inline-flex items-center gap-1 transition-colors" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                            </svg>
                            <% end %>
                        </td>
                    </tr>
                    <% end %>
                </tbody>
            </table>
        </div>

        <!-- Empty State -->
        <% if @date_summaries.empty? %>
        <div class="p-8 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <h3 class="mt-2 text-sm font-medium text-white">Nenhum balanço encontrado</h3>
            <p class="mt-1 text-sm text-slate-400">Gere o seu primeiro balanço diário usando o formulário acima.</p>
        </div>
        <% end %>
    </div>
</div>